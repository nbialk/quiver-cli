# Secrets for MCP server configuration.
#
# Copy this file to `.env.local` in your repo root and fill in the values you
# need. The agents sync script (`pnpm agents:sync`) reads `.env.local` and
# interpolates these into the generated `.mcp.json` / `opencode.json`.
#
# `.env.local` is gitignored automatically by `nb-agents init`. Never commit it.
# Only set the variables for the MCP servers you actually keep.

# Neon (Postgres) MCP — personal API key from https://console.neon.tech
NEON_API_KEY=

# Langfuse data-platform MCP — base64 of "pk-lf-...:sk-lf-..."
# Generate with: echo -n "pk-lf-your-public:sk-lf-your-secret" | base64
LANGFUSE_MCP_TOKEN=

# The following MCP servers need NO secret here:
#   - playwright    (local)
#   - langfuse-docs (public)
#   - context7      (keyless; optional CONTEXT7_API_KEY header for higher limits)
#   - vercel        (OAuth on first use)
#   - notion        (OAuth on first use)
#   - posthog       (OAuth on first use)
